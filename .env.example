# HydraClone - Configuración de Variables de Entorno
# Copia este archivo a .env y completa con tus credenciales

# GitHub
# Obtén el token en: https://github.com/settings/tokens
# Requiere permisos: repo, read:user
GITHUB_TOKEN=

# GitLab
# Obtén el token en: https://gitlab.com/profile/personal_access_tokens
# Requiere permisos: read_api, read_user, read_repository
GITLAB_TOKEN=

# Bitbucket
# Obtén el token en: https://bitbucket.org/account/settings/personal-access-tokens/
# Requiere permisos: account, repository
BITBUCKET_TOKEN=
BITBUCKET_USER=

# Opcional: Directorio base para clonar repositorios
# Por defecto se usa PROJECT_ROOT/clones/
# CLONES_BASE_DIR=/ruta/personalizada/para/clones

# Opcional: Directorio para guardar reportes
# Por defecto se usa PROJECT_ROOT/reports/
# REPORTS_DIR=/ruta/personalizada/para/reportes
